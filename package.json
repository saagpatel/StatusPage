{
  "name": "statuspage-sh",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=web",
    "dev:api": "bash scripts/with-dotenv.sh cargo run -p api-server --bin api-server",
    "dev:monitor": "bash scripts/with-dotenv.sh cargo run -p monitor",
    "dev:lean": "bash scripts/dev-lean.sh",
    "setup:local": "bash scripts/setup-local-env.sh",
    "verify": "bash .codex/scripts/run_verify_commands.sh",
    "verify:managed": "bash scripts/verify-managed.sh",
    "verify:fast": "pnpm web:lint && pnpm web:test && pnpm web:typecheck && pnpm rust:fmt && pnpm rust:clippy",
    "verify:perf": "pnpm perf:build && pnpm perf:bundle && pnpm perf:assets && pnpm perf:memory && pnpm perf:summary && node scripts/perf/compare-metric.mjs .perf-baselines/build-time.json .perf-results/build-time.json buildMs 0.15 && node scripts/perf/compare-metric.mjs .perf-baselines/bundle.json .perf-results/bundle.json totalBytes 0.08",
    "smoke:local": "bash scripts/smoke-local.sh",
    "smoke:managed": "bash scripts/smoke-managed.sh",
    "smoke:prod": "bash scripts/smoke-prod.sh",
    "smoke:email": "bash scripts/smoke-email.sh",
    "smoke:webhooks": "bash scripts/smoke-webhooks.sh",
    "docker:prod:build": "docker compose -f docker/docker-compose.prod.yml build",
    "docker:prod:up": "docker compose -f docker/docker-compose.prod.yml up -d",
    "docker:prod:down": "docker compose -f docker/docker-compose.prod.yml down",
    "docker:prod:reset": "docker compose -f docker/docker-compose.prod.yml down -v --remove-orphans",
    "rehearse:prod": "bash scripts/rehearse-prod.sh",
    "rehearse:rollback": "bash scripts/rehearse-rollback.sh",
    "backup:prod": "bash scripts/backup-postgres.sh",
    "restore:prod": "bash scripts/restore-postgres.sh",
    "e2e:auth": "bash scripts/run-auth-e2e.sh",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "web:lint": "pnpm --filter web lint",
    "web:test": "pnpm --filter web test",
    "web:typecheck": "pnpm --filter web typecheck",
    "web:build": "pnpm --filter web build",
    "rust:fmt": "cargo fmt --all -- --check",
    "rust:clippy": "cargo clippy --workspace --all-targets --all-features -- -D warnings",
    "rust:test": "cargo test --workspace",
    "perf:bundle": "node scripts/perf/bundle-report.mjs",
    "perf:build": "node scripts/perf/measure-build-time.mjs",
    "perf:assets": "bash scripts/perf/check-assets.sh",
    "perf:memory": "node --expose-gc scripts/perf/memory-smoke.mjs",
    "perf:summary": "node scripts/perf/summarize.mjs",
    "clean:heavy": "bash scripts/clean-local.sh heavy",
    "clean:full": "bash scripts/clean-local.sh full",
    "db:up": "bash scripts/dev-db-up.sh",
    "db:down": "docker compose --env-file .env -f docker/docker-compose.dev.yml down",
    "db:migrate": "bash scripts/with-dotenv.sh cargo run -p api-server --bin migrate",
    "db:seed": "bash scripts/with-dotenv.sh cargo run -p api-server --bin seed"
  },
  "devDependencies": {
    "turbo": "^2"
  },
  "pnpm": {
    "overrides": {
      "@babel/core": "7.29.7",
      "ajv": "6.14.0",
      "brace-expansion": "1.1.15",
      "esbuild": "0.28.1",
      "flatted": "3.4.2",
      "js-yaml": "4.2.0",
      "minimatch": "3.1.5",
      "postcss": "8.5.16",
      "tmp": "0.2.7",
      "uuid": "11.1.1",
      "vite": "8.1.3"
    }
  },
  "packageManager": "pnpm@9.15.4"
}
